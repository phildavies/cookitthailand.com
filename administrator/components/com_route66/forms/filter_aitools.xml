<?xml version="1.0" encoding="UTF-8"?>
<form addfieldprefix="Firecoders\Component\Route66\Administrator\Field">
    <fields name="filter">
        <field name="search" type="text" inputmode="search" label="COM_ROUTE66_PAGES_FILTER_SEARCH_LABEL" hint="JSEARCH_FILTER" />
        <field name="state" type="list" label="JSTATUS" class="js-select-submit-on-change">
            <option value="">JLIB_HTML_SELECT_STATE</option>
            <option value="1">JENABLED</option>
            <option value="0">JDISABLED</option>
        </field>
    </fields>
    <fields name="list">
        <field name="fullordering" type="list" label="JGLOBAL_SORT_BY" class="js-select-submit-on-change" default="aitool.id ASC" validate="options">
            <option value="">JGLOBAL_SORT_BY</option>
            <option value="aitool.title ASC">JGLOBAL_TITLE_ASC</option>
            <option value="aitool.title DESC">JGLOBAL_TITLE_DESC</option>
            <option value="aitool.ordering ASC">JGRID_HEADING_ORDERING_ASC</option>
            <option value="aitool.ordering DESC">JGRID_HEADING_ORDERING_DESC</option>
            <option value="aitool.state ASC">JSTATUS_ASC</option>
            <option value="aitool.state DESC">JSTATUS_DESC</option>
            <option value="aitool.id ASC">JGRID_HEADING_ID_ASC</option>
            <option value="aitool.id DESC">JGRID_HEADING_ID_DESC</option>
        </field>
        <field name="limit" type="limitbox" label="JGLOBAL_LIST_LIMIT" default="25" class="js-select-submit-on-change" />
    </fields>
</form>
