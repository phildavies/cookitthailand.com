<?xml version="1.0" ?>
<extension version="3.4" type="plugin" group="jce" method="upgrade">
	<name>WF_SOURCE_TITLE</name>
	<version>2.9.97</version>
	<creationDate>15-12-2025</creationDate>
	<author>Ryan Demmer</author>
	<authorEmail>info@joomlacontenteditor.net</authorEmail>
	<authorUrl>https://www.joomlacontenteditor.net/</authorUrl>
	<copyright>Copyright (C) 2006 - 2025 Ryan Demmer. All rights reserved</copyright>
	<license>GNU/GPL Version 2 or later - http://www.gnu.org/licenses/gpl-2.0.html</license>
	<description>WF_SOURCE_DESC</description>
	<icon></icon>
	<fields name="source">
		<fieldset name="config">
			<field name="highlight" type="yesno" default="1" label="WF_SOURCE_HIGHLIGHT" description="WF_SOURCE_HIGHLIGHT_DESC">
				<option value="1">JON</option>
				<option value="0">JOFF</option>
			</field>
			<field name="numbers" type="yesno" default="1" label="WF_SOURCE_NUMBERS" description="WF_SOURCE_NUMBERS_DESC">
				<option value="1">JON</option>
				<option value="0">JOFF</option>
			</field>
			<field name="wrap" type="yesno" default="1" label="WF_SOURCE_WRAP" description="WF_SOURCE_WRAP_DESC">
				<option value="1">JON</option>
				<option value="0">JOFF</option>
			</field>
			<field name="format" type="yesno" default="1" label="WF_SOURCE_FORMAT" description="WF_SOURCE_FORMAT_DESC">
				<option value="1">JYES</option>
				<option value="0">JNO</option>
			</field>
			<field name="tag_closing" type="yesno" default="1" label="WF_SOURCE_TAG_CLOSING" description="WF_SOURCE_TAG_CLOSING_DESC">
				<option value="1">JYES</option>
				<option value="0">JNO</option>
			</field>

			<field name="validate_content" type="yesno" default="1" label="WF_SOURCE_VALIDATE_CONTENT" description="WF_SOURCE_VALIDATE_CONTENT_DESC">
				<option value="1">JYES</option>
				<option value="0">JNO</option>
			</field>

			<field name="theme" type="list" default="codemirror" label="WF_SOURCE_THEME" description="WF_SOURCE_THEME_DESC">
				<option value="codemirror">Default Light</option>
				<option value="codemirror-dark">Default Dark</option>
				<option value="ayuLight">Ayu Light</option>
				<option value="bespin">Bespin</option>
				<option value="clouds">Clouds</option>
				<option value="cobalt">Cobalt</option>
				<option value="dracula">Dracula</option>
				<option value="espresso">Espresso</option>
				<option value="noctisLilac">Noctis Lilac</option>
				<option value="smoothy">Smoothy</option>
				<option value="solarizedLight">Solarized</option>
				<option value="tomorrow">Tomorrow</option>
				<option value="rosePineDawn">Rose Pine Dawn</option>
			</field>

			<field name="font_size" type="number" min="8" step="1" default="" label="WF_SOURCE_FONT_SIZE" description="WF_SOURCE_FONT_SIZE_DESC" placeholder="eg: 16" />
			<field name="line_height" type="number" min="8" step="1" default="" label="WF_SOURCE_LINE_HEIGHT" description="WF_SOURCE_LINE_HEIGHT_DESC" placeholder="eg: 24" />

		</fieldset>
	</fields>
	<help>
		<topic key="source.about" title="WF_SOURCE_HELP_ABOUT" />
	</help>
	<languages></languages>
</extension>
